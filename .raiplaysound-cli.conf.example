# RaiPlaySound CLI user defaults
#
# Install for current user:
#   cp .raiplaysound-cli.conf.example ~/.raiplaysound-cli.conf
#
# Format is simple KEY=VALUE (env-style file, no sections).
# Empty/commented keys are ignored.

# Base folder for all program downloads.
TARGET_BASE="$HOME/Music/RaiPlaySound"

# Default audio output format.
AUDIO_FORMAT="m4a"

# Default parallel downloads.
JOBS=3

# Optional default command.
# Values: download, list
# COMMAND="download"

# Optional default list target when COMMAND="list".
# Values: stations, programs, seasons, episodes
# LIST_TARGET=""

# Default metadata-cache max age (hours).
METADATA_MAX_AGE_HOURS=24

# Default parallel workers used to check archived entries vs local files.
CHECK_JOBS=8

# Optional default season selection. Examples: "1", "1,2", "all"
# Used by:
# - download mode
# - list mode when LIST_TARGET="episodes"
# SEASONS_ARG=""

# Optional default grouping selection for non-season grouped programs.
# Examples: "speciali", "speciale-lucio-dalla", "repliche"
# Used by:
# - download mode
# - list mode when LIST_TARGET="episodes"
# Cannot be combined with SEASONS_ARG.
# GROUPS_ARG=""

# Optional default episode-ID filters for download mode (comma-separated IDs).
# Maps to: download --episode-ids
# EPISODES_ARG=""

# Optional default episode-URL filters for download mode (comma-separated URLs).
# EPISODE_URLS_ARG=""

# Optional default behavior: re-download archived episodes whose files are missing.
# Values: 1/0, true/false, yes/no, on/off
# AUTO_REDOWNLOAD_MISSING=0
# Optional alias with same behavior:
# DOWNLOAD_MISSING=0

# Optional default: include episode URLs in list episodes output.
# SHOW_URLS=0

# Optional default: show detailed station listing with URLs.
# Requires LIST_TARGET="stations".
# STATIONS_DETAILED=0

# Optional program listing grouping mode.
# Values: auto, alpha, station
# auto: station grouping when no --filter, alphabetical grouping when --filter is set
# GROUP_BY="auto"
# Legacy alias still accepted:
# PODCASTS_GROUP_BY="auto"

# Optional flat alphabetic output (no grouping) for program listing.
# Values: 1/0, true/false, yes/no, on/off
# PODCASTS_SORTED=0

# Optional station slug filter for program listing.
# Examples: radio1, radio2, radio3, isoradio, nonameradio, none
# STATION_FILTER=""

# Optional default: force refresh of program catalog cache when listing programs.
# FORCE_REFRESH_CATALOG=0

# Optional program catalog cache max age (hours).
# Default is 2160 hours (90 days).
# This is intentionally longer-lived than the per-show metadata cache, which
# defaults to 24 hours.
# Use --refresh-catalog to force a rebuild on one run, or lower this value if
# you want fresher program listings by default.
# Example 24-hour override:
# CATALOG_MAX_AGE_HOURS=24

# Optional program catalog cache file path.
# CATALOG_CACHE_FILE="$HOME/.local/state/raiplaysound-cli/program-catalog.tsv"

# Optional default: enable verbose debug logging.
# ENABLE_LOG=0

# Optional default: log worker PID / yt-dlp PID lifecycle transitions.
# Writes PID traces to the per-run log file.
# DEBUG_PIDS=0

# Optional default log destination.
# - empty: log in program output dir
# - directory path: creates <program_slug>-run-YYYYMMDD-HHMMSS.log in that dir
# - file path: writes directly to that file
# LOG_PATH_ARG=""

# Optional default: force metadata refresh every run.
# FORCE_REFRESH_METADATA=0

# Optional default: clear metadata cache before run.
# CLEAR_METADATA_CACHE=0

# Optional default input when you do not pass program_slug/program_url on CLI.
# Also used for list mode when LIST_TARGET is "seasons" or "episodes".
# INPUT="musicalbox"

# Optional: generate an M3U playlist (playlist.m3u) in the show's download folder
# after every run. The playlist is built from the metadata cache and all locally
# present audio files, sorted oldest-to-newest. File paths are relative to the
# playlist file so the folder stays portable. Off by default.
# Values: 1/0, true/false, yes/no, on/off
# PLAYLIST=false

# Optional: generate a standard RSS 2.0 podcast feed (feed.xml) in the show's
# download folder after every run. The feed is built from the metadata cache and
# all locally present audio files, so it stays accurate even on re-runs where
# all episodes are already downloaded. Off by default.
# Values: 1/0, true/false, yes/no, on/off
# RSS_FEED=false

# Optional: base URL for the parent folder containing all show subfolders.
# When set, RSS enclosure URLs are built as <RSS_BASE_URL>/<program_slug>/<filename>
# instead of local file:// absolute paths. This makes the feed usable from any
# podcast client on any device.
#
# RSS_BASE_URL must be a direct file-serving base URL.
# The CLI appends /<program_slug>/<filename> to it.
#
# Works:
# RSS_BASE_URL=https://media.example.net/RaiPlaySound
#
# Does not work:
# RSS_BASE_URL=https://files.example.net/share?code=abcd1234
# RSS_BASE_URL=
